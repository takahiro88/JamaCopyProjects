    {
        "createdBy": 32,
        "createdDate": "2025-10-21T05:22:30.000+0000",
        "documentKey": "MS56-MSR2-21",
        "fields": {
            "description": "<h1>関数</h1>\n\n<pre>VD ad(VD)</pre>\n\n<h1>入力</h1>\n\n<p>\"-\"で省略している項目は、ｂｂｂを参照。</p>\n\n<table border=\"1\" cellpadding=\"1\" cellspacing=\"0\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"col\">種別</th>\n\t\t\t<th scope=\"col\">入出力兼用</th>\n\t\t\t<th scope=\"col\">項目</th>\n\t\t\t<th scope=\"col\">識別子</th>\n\t\t\t<th scope=\"col\">型</th>\n\t\t\t<th scope=\"col\">備考</th>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td colspan=\"1\">あいうえおかきくけこさしすせそ</td>\n\t\t\t<td colspan=\"1\">NO</td>\n\t\t\t<td>abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMN</td>\n\t\t\t<td>-</td>\n\t\t\t<td>-</td>\n\t\t\t<td>-</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td colspan=\"1\">たちつてとなにぬねのはひふへほ</td>\n\t\t\t<td colspan=\"1\">NO</td>\n\t\t\t<td>OPQRSTUVWXYZ１２３４５６７８９０１２３４５</td>\n\t\t\t<td>-</td>\n\t\t\t<td>-</td>\n\t\t\t<td>-</td>\n\t\t</tr>\n\t</thead>\n\t<tbody>\n\t</tbody>\n</table>\n\n<h1>出力</h1>\n\n<p>\"-\"で省略している項目は、ｂｂｂを参照。</p>\n\n<table border=\"1\" cellpadding=\"1\" cellspacing=\"0\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"col\">種別</th>\n\t\t\t<th scope=\"col\">入出力兼用</th>\n\t\t\t<th scope=\"col\">項目</th>\n\t\t\t<th scope=\"col\">識別子</th>\n\t\t\t<th scope=\"col\">型</th>\n\t\t\t<th scope=\"col\">備考</th>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td colspan=\"1\" rowspan=\"1\">まみむめもやゆよらりるれろわをんあいうえおかきくけこさしすせそ</td>\n\t\t\t<td colspan=\"1\" rowspan=\"1\">NO</td>\n\t\t\t<td>１２３４５６７８９０１２３４５</td>\n\t\t\t<td>-</td>\n\t\t\t<td>-</td>\n\t\t\t<td>-</td>\n\t\t</tr>\n\t</thead>\n</table>\n\n<h1>処理</h1>\n\n<h2>概要</h2>\n\n<p>仕向けを出力する。</p>\n\n<h2>出力処理</h2>\n\n<p>下表に基づき出力:[仕向け国]に値を設定する。空セルは任意の値を意味する。</p>\n\n<table border=\"1\" cellpadding=\"1\" cellspacing=\"0\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th colspan=\"2\" rowspan=\"1\" scope=\"col\">条件</th>\n\t\t\t<th scope=\"col\">出力</th>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th scope=\"col\">入力:[]</th>\n\t\t\t<th scope=\"col\">入力:[]</th>\n\t\t\t<th scope=\"col\">出力:[仕向け国]</th>\n\t\t</tr>\n\t</thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<td>システムバリ_日本</td>\n\t\t\t<td>&nbsp;</td>\n\t\t\t<td>仕向け国_日本</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td>システムバリ_北米</td>\n\t\t\t<td>&nbsp;</td>\n\t\t\t<td>仕向け国_北米</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td>システムバリ_中国/オーストラリア/ニュージーランド</td>\n\t\t\t<td>DCMあり緊急通報なし</td>\n\t\t\t<td>仕向け国_中国/オーストラリア</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td>システムバリ_中国/オーストラリア/ニュージーランド</td>\n\t\t\t<td>緊急通報あり</td>\n\t\t\t<td>仕向け国_中国/オーストラリア</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td>システムバリ_中国/オーストラリア/ニュージーランド</td>\n\t\t\t<td>DCMなし</td>\n\t\t\t<td>仕向け国_ニュージーランド</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td>システムバリ_欧州</td>\n\t\t\t<td>&nbsp;</td>\n\t\t\t<td>仕向け国_欧州</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td>\n\t\t\t<p>(システムバリ_日本、システムバリ_北米、</p>\n\n\t\t\t<p>システムバリ_中国/オーストラリア/ニュージーランド、</p>\n\n\t\t\t<p>システムバリ_欧州)以外</p>\n\t\t\t</td>\n\t\t\t<td>&nbsp;</td>\n\t\t\t<td>仕向け国_EDSSなしの国・地域</td>\n\t\t</tr>\n\t</tbody>\n</table>\n",
            "documentKey": "MS56-MSR2-21",
