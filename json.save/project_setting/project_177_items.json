    {
        "createdBy": 14,
        "createdDate": "2024-12-24T04:38:05.000+0000",
        "documentKey": "TSYNC-SR-5",
        "fields": {
            "SubsysReqStat$86": "0%",
            "description": "<p>Many hearing aid on the market require a pendant or other device to transfer sound between the hearing aid and the iOS device. If we want to increase market share amongst younger patients, especially those who are Apple-focused, we need to find a way to directly integrate with iOS.　</p>\n",
            "documentKey": "TSYNC-SR-5",
            "globalId": "GID-61343",
            "name": "iOS Integration",
            "status": 293
        },
