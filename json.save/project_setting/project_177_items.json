        "createdDate": "2024-12-24T04:38:05.000+0000",
        "documentKey": "TSYNC-SR-7",
        "fields": {
            "SubsysReqStat$86": "0%",
            "description": "<p><span style=\"font-size:13px\">Many hearing aids on the market require a pendant or other device to transfer sound between the hearing aid and the Windows device. If we want to increase market share amongst younger patients, especially those who are Windows-focused, we need to find a way to directly integrate with Windows.</span></p>",
