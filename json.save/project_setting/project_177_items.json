        "createdDate": "2024-12-24T04:38:05.000+0000",
        "documentKey": "TSYNC-SR-6",
        "fields": {
            "SubsysReqStat$86": "0%",
            "description": "<p><span style=\"font-size:13px\">Many hearing aid on the market require a pendant or other device to transfer sound between the hearing aid and the SymbianOS. If we want to increase market share amongst younger patients in Asia, primarily Japan, we need to find a way to directly integrate with SymbianOS.</span></p>\n\n<p>&nbsp;</p>\n\n<p><span style=\"font-size:13px\">Symboan -&gt; Android&nbsp; Configure</span></p>\n",
            "documentKey": "TSYNC-SR-6",
            "globalId": "GID-61344",
            "name": "SymbianOS Integration",
            "status": 512
        },
        "globalId": "GID-61344",
