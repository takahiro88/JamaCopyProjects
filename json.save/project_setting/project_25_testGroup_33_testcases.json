                {
                    "action": "Display &quot;Battery Door&quot; label to patient",
                    "expectedResult": "Correct identification within 5 seconds",
                    "notes": ""
                },
                {
                    "action": "Display &quot;Volume Control&quot; label to patient",
                    "expectedResult": "Correct identification within 5 seconds",
                    "notes": ""
