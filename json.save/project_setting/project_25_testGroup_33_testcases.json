        "documentKey": "CL3-VAL-7",
        "fields": {
            "description": "<p>The hearing aid should be more adoptable than other comparable hearing aids. &nbsp;This will be validated by using a patient focus group. &nbsp;A patient from the group&nbsp;will be given a set of tasks and the time to complete the tasks will be measured.</p>\n\n<p>&nbsp;</p>\n\n<p>Each step in the validation is a separate patient.</p>",
            "documentKey": "CL3-VAL-7",
            "globalId": "GID-53301",
            "name": "Intuitive Design - Battery Replacement",
            "status": 292,
            "testCaseStatus": "FAILED",
            "testCaseSteps": [
                {
                    "action": "Give the user a packaged battery and measure the time it takes them to insert the battery into the device",
                    "expectedResult": "5 minutes",
                    "notes": ""
                },
                {
                    "action": "Give a second user a packaged battery and have them watch a 1 minute video describing the battery replacement",
                    "expectedResult": "",
                    "notes": "setup"
                },
                {
                    "action": "Give the second user a packaged battery and measure the time it takes them to insert the battery and re-attach the device",
                    "expectedResult": "2 minutes",
                    "notes": ""
                }
            ],
            "testRunResults": {
