        "documentKey": "AIS-VAL-19",
        "fields": {
            "description": "<p>To simulate dynamic acceleration during driving on a curve, the sensor is checked by gravitational acceleration under static conditions. The method involves positioning the vehicle on a transverse ramp with known angle of inclination and comparing the acceleration force measured by the lateral-acceleration sensor with a preset sensor value determined on the basis of the angle of inclination of the ramp.</p>\n\n<p>&nbsp;</p>\n\n<p><img alt=\"\" height=\"125\" src=\"https://acceleratedsoftware.jamacloud.com/attachment/307/Screen%20Shot%202017-10-30%20at%204.44.16%20PM.png\" width=\"300\" /></p>",
            "documentKey": "AIS-VAL-19",
            "globalId": "GID-55557",
            "name": "Detect accurate lateral acceleration",
            "status": 293,
            "testCaseStatus": "PASSED",
            "testCaseSteps": [
                {
                    "action": "positioning the vehicle on a transverse ramp with known angle of inclination",
                    "expectedResult": "",
                    "notes": ""
                },
                {
                    "action": "compare acceleration force measured by the lateral-acceleration sensor with the preset sensor value",
                    "expectedResult": "",
                    "notes": ""
                }
            ],
            "testRunResults": {
                "id": 0,
                "numBlocked": 0,
                "numFailed": 0,
                "numInProgress": 0,
                "numNotApplicable": 0,
                "numNotRun": 0,
                "numPassed": 1,
                "numTotalRuns": 1
            }
        },
