    {
        "createdBy": 5,
        "createdDate": "2017-10-31T17:42:16.000+0000",
        "documentKey": "AIS-VAL-22",
        "fields": {
            "description": "<p>Each sensor is part of a two sensor system. If their is a failure in a sensor due to power outage or other anomalies, the other sensor will continue to work. When both sensors are functional, each sensor checks itself against the other with a variance of 1ms.</p>\n\n<p>&nbsp;</p>\n\n<p>If a sensor has a failure, a dashboard warning should be set notifying the driver to have the vehicle checked.&nbsp;</p>",
            "documentKey": "AIS-VAL-22",
            "globalId": "GID-55560",
            "name": "Detect accurate response from impact sensors",
            "status": 293,
            "testCaseStatus": "FAILED",
            "testCaseSteps": [
                {
                    "action": "turn of sensor 1",
                    "expectedResult": "dashboard warning should be visible",
                    "notes": ""
                },
                {
                    "action": "turn off both sensors",
                    "expectedResult": "dashboard warning should be visible",
                    "notes": ""
                },
                {
                    "action": "turn on both sensors",
                    "expectedResult": "no dashboard warning visible",
                    "notes": ""
                },
                {
                    "action": "conduct front bumper impact with both sensors active",
                    "expectedResult": "response from sensors should have a variance of 1ms or less",
                    "notes": ""
                },
                {
                    "action": "conduct rear bumper impact with both sensors active",
                    "expectedResult": "response from sensors should have a variance of 1ms or less",
                    "notes": ""
                },
                {
                    "action": "conduct driver side impact with both sensors active",
                    "expectedResult": "response from sensors should have a variance of 1ms or less",
                    "notes": ""
                },
                {
                    "action": "conduct passenger side impact with both sensors active",
                    "expectedResult": "response from sensors should have a variance of 1ms or less",
                    "notes": ""
                }
            ],
            "testRunResults": {
                "id": 0,
                "numBlocked": 0,
                "numFailed": 1,
                "numInProgress": 0,
                "numNotApplicable": 0,
                "numNotRun": 0,
