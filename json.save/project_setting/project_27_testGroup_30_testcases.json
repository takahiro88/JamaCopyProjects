        "createdDate": "2017-10-31T17:50:45.000+0000",
        "documentKey": "AIS-VAL-24",
        "fields": {
            "description": "<p>The rear safety child seat sensor should accurately detect a child sitting in a child seat in the back passenger seats.</p>\n\n<p>&nbsp;</p>\n\n<p>This measure should be based on a weight of more than 10 lbs and less than 50 lbs.</p>\n\n<p>&nbsp;</p>\n\n<p>The sensor should automatically disable the rear airbag and enable dashboard warning of child in.</p>",
            "documentKey": "AIS-VAL-24",
            "globalId": "GID-55562",
            "name": "Detect child in safety seat rear passenger side seat",
            "status": 293,
            "testCaseStatus": "PASSED",
            "testCaseSteps": [
                {
                    "action": "put 5 lb safety certified child seat in rear passenger side seat",
                    "expectedResult": "airbag remains on. dashboard warning remains off",
                    "notes": ""
                },
                {
                    "action": "put 10 lb sand bag in safety seat",
                    "expectedResult": "airbag turns off. warning light turns on.",
                    "notes": ""
                },
                {
                    "action": "put 20 lb sand bag in safety seat",
                    "expectedResult": "airbag turns off. warning light turns on.",
                    "notes": ""
                },
                {
                    "action": "put 50 lbs sand bag in safety seat",
                    "expectedResult": "airbag stays on. No warning light on dashboard",
                    "notes": ""
                },
                {
                    "action": "put 4 lbs sand bag in safety seat",
                    "expectedResult": "airbag stays off. warning light does not appear.",
                    "notes": ""
                }
            ],
            "testRunResults": {
                "id": 0,
                "numBlocked": 0,
                "numFailed": 0,
                "numInProgress": 0,
                "numNotApplicable": 0,
                "numNotRun": 0,
