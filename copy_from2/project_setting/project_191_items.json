    {
        "createdBy": 39,
        "createdDate": "2025-08-06T07:14:40.000+0000",
        "documentKey": "Sample_ProjA-FR-1",
        "fields": {
            "description": "<p>ユーザー登録時、パスワードは8文字以上で、英大文字・小文字・数字・記号を各1文字以上含み、一般的な単語や過去のパスワードは使用不可とする。</p>\n",
            "documentKey": "Sample_ProjA-FR-1",
            "globalId": "GID-86396",
            "name": "パスワードポリシーの適用",
            "status": 292
        },
